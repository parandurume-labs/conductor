flowchart TD
    C((구조적 사고)) --> G["🎯 목표\n무엇을 달성하려는가?"]
    C --> S["🔧 수단\n어떤 형태여야 하는가?"]
    C --> P["🌐 플랫폼\n어디서 사람들이 접하는가?"]
    C --> A["👥 대상\n누구를 위한 것인가?"]
    C --> I["🔗 연동\n무엇과 연결되는가?"]
    C --> L["⏳ 제약\n한계가 뭔가?"]
    C --> Q["✨ 품질\n얼마나 좋아야 하는가?"]

    style C fill:#4A90D9,color:#fff,stroke:#2E6BB0,stroke-width:3px
    style G fill:#E8F5E9,stroke:#43A047
    style S fill:#FFF3E0,stroke:#FB8C00
    style P fill:#E3F2FD,stroke:#1E88E5
    style A fill:#FCE4EC,stroke:#E91E63
    style I fill:#F3E5F5,stroke:#8E24AA
    style L fill:#FFF9C4,stroke:#F9A825
    style Q fill:#E0F7FA,stroke:#00ACC1
